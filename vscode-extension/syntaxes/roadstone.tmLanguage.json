{
  "name": "Roadstone",
  "scopeName": "source.roadstone",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#definitions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.roadstone",
          "match": "--.*$"
        }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "name": "entity.name.class.roadstone",
          "match": "(?<=\\bCLASS\\s)([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.function.roadstone",
          "match": "(?<=\\bdefi\\s)([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.roadstone",
          "match": "\\b(if|elseif|else|while|for|in|then|loop|end|return|and|or|not|EXCEPT|exoutput)\\b"
        },
        {
          "name": "storage.modifier.roadstone",
          "match": "\\b(local|global)\\b"
        },
        {
          "name": "storage.type.class.roadstone",
          "match": "\\b(CLASS|construct|extends)\\b"
        },
        {
          "name": "storage.type.function.roadstone",
          "match": "\\bdefi\\b"
        },
        {
          "name": "variable.language.roadstone",
          "match": "\\b(self|exname|extarget|exmessage)\\b"
        },
        {
          "name": "constant.language.boolean.roadstone",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.roadstone",
          "match": "\\b(print|len|keys|values|sort|push|contains|type|raise|error|Ask|Int|analyze|input|store)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.roadstone",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.roadstone",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.roadstone",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.roadstone",
          "match": "(==|!=|<=|>=|<|>|\\+|-|\\*|/|%|\\.\\.|=)"
        },
        {
          "name": "punctuation.separator.key-value.roadstone",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.roadstone",
          "match": "[,;]"
        },
        {
          "name": "punctuation.section.parens.roadstone",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.roadstone",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.braces.roadstone",
          "match": "[{}]"
        }
      ]
    }
  },
  "fileTypes": [
    "rd"
  ],
  "uuid": "e7e86c76-2f3d-4f3d-9a4b-fb7f2c2b0c01"
}
